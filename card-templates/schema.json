{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://perks-reminder.com/schemas/card-template.json",
  "title": "Perks Reminder Card Template",
  "type": "object",
  "required": ["name", "issuer", "annualFee", "imageUrl", "sources", "benefits"],
  "additionalProperties": false,
  "properties": {
    "$schema": { "type": "string" },
    "name": { "type": "string", "minLength": 1 },
    "issuer": { "type": "string", "minLength": 1 },
    "annualFee": { "type": "number", "minimum": 0 },
    "imageUrl": { "type": "string", "pattern": "^/images/cards/.+" },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["label", "url"],
        "additionalProperties": false,
        "properties": {
          "label": { "type": "string", "minLength": 1 },
          "url": { "type": "string", "format": "uri" },
          "accessed": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" }
        }
      }
    },
    "benefits": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["description", "category", "maxAmount", "frequency"],
        "additionalProperties": false,
        "properties": {
          "description": { "type": "string", "minLength": 1 },
          "category": { "type": "string", "minLength": 1 },
          "maxAmount": { "type": "number", "minimum": 0 },
          "frequency": {
            "type": "string",
            "enum": ["MONTHLY", "QUARTERLY", "YEARLY", "ONE_TIME"]
          },
          "cycleAlignment": {
            "type": "string",
            "enum": ["CARD_ANNIVERSARY", "CALENDAR_FIXED"]
          },
          "fixedCycleStartMonth": { "type": "integer", "minimum": 1, "maximum": 12 },
          "fixedCycleDurationMonths": { "type": "integer", "minimum": 1, "maximum": 120 },
          "occurrencesInCycle": { "type": "integer", "minimum": 1 },
          "notes": { "type": "string" }
        }
      }
    },
    "reviewNotes": { "type": "string" }
  }
}
